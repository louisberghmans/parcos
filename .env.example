# Copy this file to .env before the first start.
PARCOS_PORT=8080
PARCOS_ADMIN_USERNAME=admin
PARCOS_ADMIN_PASSWORD=replace-with-a-long-unique-password

# Set these when ParcOS is served through HTTPS at its final address.
# Example: https://parcos.example.org
PARCOS_BASE_URL=
PARCOS_COOKIE_SECURE=false
PARCOS_TRUST_PROXY=false
